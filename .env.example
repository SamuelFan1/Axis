# Axis application
AXIS_HTTP_ADDRESS=:9090
AXIS_NODE_TIMEOUT_SEC=30
AXIS_NODE_MONITOR_INTERVAL_SEC=5

# Axis auth
AXIS_ADMIN_USERNAME=admin
AXIS_ADMIN_PASSWORD=change_me_now
AXIS_NODE_SHARED_TOKEN=change_me_node_token
AXIS_AUTH_REALM=Axis Admin

# Axis CLI no longer reads database settings directly.
# Use axis-rc.sh.example for admin shell access.

# Axis database
AXIS_DB_HOST=127.0.0.1
AXIS_DB_PORT=4000
AXIS_DB_USER=root
AXIS_DB_PASSWORD=change_me
AXIS_DB_NAME=AXIS
AXIS_DB_MAX_OPEN_CONNS=10
AXIS_DB_MAX_IDLE_CONNS=5

# Region/Zone config (ISO-3166-1 alpha-2, reference Cloudflare)
AXIS_REGIONS=asia,europe,australia,north_america,south_america
AXIS_LOCAL_REGION=asia
AXIS_REGION_ASIA_ZONES=SG,CN,JP,KR,HK,TW,IN,TH,VN,ID,MY,PH
AXIS_REGION_EUROPE_ZONES=DE,GB,FR,NL,IT,ES,PL,SE,CH,AT
AXIS_REGION_AUSTRALIA_ZONES=AU,NZ
AXIS_REGION_NORTH_AMERICA_ZONES=US,CA,MX
AXIS_REGION_SOUTH_AMERICA_ZONES=BR,AR,CL,CO,PE

# Optional DNS automation
AXIS_DNS_ENABLED=false
AXIS_DNS_PROVIDER=cloudflare
AXIS_DNS_ZONE=github.com
AXIS_DNS_RECORD_PREFIX=dl-
AXIS_DNS_RECORD_TYPE=A
AXIS_DNS_TTL=1
AXIS_DNS_PROXIED=false
AXIS_DNS_CLOUDFLARE_API_TOKEN=
