#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [ -z "${AXIS_API_URL:-}" ] || [ -z "${AXIS_ADMIN_USERNAME:-}" ] || [ -z "${AXIS_ADMIN_PASSWORD:-}" ]; then
  echo "Axis CLI requires an admin shell environment."
  echo "Please run: source /apps/Axis/axis-rc.sh"
  exit 1
fi

if [ "${AXIS_PROFILE:-}" != "admin" ]; then
  echo "Axis CLI requires AXIS_PROFILE=admin."
  echo "Please run: source /apps/Axis/axis-rc.sh"
  exit 1
fi

cd "${ROOT_DIR}"

go run ./cmd/axis "$@"
